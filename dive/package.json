{
  "name": "dive",
  "private": true,
  "version": "1.0.0-rc.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:x64": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:arm64": "tauri build --target aarch64-pc-windows-msvc --bundles nsis",
    "tauri:build:all": "pnpm tauri:build:x64 && pnpm tauri:build:arm64",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:production-wire": "node scripts/verify-production-wire.mjs",
    "verify:v4:track-a": "node scripts/verify-track-a.mjs",
    "verify:v4:track-b": "node scripts/verify-track-b.mjs",
    "verify:v4:track-c": "node scripts/verify-track-c.mjs",
    "verify:v4:track-f": "node scripts/verify-track-f.mjs",
    "release:smoke": "node scripts/release-gate-smoke.mjs",
    "release:smoke:preflight": "node scripts/release-gate-smoke.mjs --preflight",
    "verify:rc1-migration": "node scripts/verify-rc1-migration.mjs",
    "verify:version-sync": "node scripts/verify-version-sync.mjs 1.0.0-rc.2"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.5.13",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^7.0.4"
  }
}
